Set keyloop to True.
While keyloop, do:
	Clearscreen.
	print_raw("Press any key (q to quit): ").
	set key to key_read().
	print_raw("You pressed: ").
	Show key.
	print_raw("\n").
	if key is equal to "q", then:
		print_raw("Quitting...\n").
		Set keyloop to False.

	else:
		print_raw("Not quitting.\n").
	end
	wait(5000).
End while.
